# Copy this file to .env and replace placeholders with values from your own
# media servers. Keep .env local; it can contain API keys, Plex tokens, private
# hostnames, and other operator-only details.
#
# `npm run audit -- ...` commands do not automatically read these names. They
# are shell helpers for repeatable export/compare commands. Source .env before
# using the examples in README.md or docs/MEDIA-CLEANUP-RUNBOOK.md:
#
#   set -a
#   . ./.env
#   set +a

# Primary server: usually the server you are reviewing or cleaning.
PRIMARY_PLEX_URL=http://primary-plex.example.local:32400
PRIMARY_PLEX_TOKEN=replace-with-primary-plex-token
PRIMARY_EMBY_URL=http://primary-emby.example.local:8096
PRIMARY_EMBY_API_KEY=replace-with-primary-emby-api-key

# Secondary server: first comparison target.
SECONDARY_PLEX_URL=http://secondary-plex.example.local:32400
SECONDARY_PLEX_TOKEN=replace-with-secondary-plex-token
SECONDARY_EMBY_URL=http://secondary-emby.example.local:8096
SECONDARY_EMBY_API_KEY=replace-with-secondary-emby-api-key

# Additional comparison targets can follow the same pattern.
TERTIARY_PLEX_URL=http://tertiary-plex.example.local:32400
TERTIARY_PLEX_TOKEN=replace-with-tertiary-plex-token
TERTIARY_EMBY_URL=http://tertiary-emby.example.local:8096
TERTIARY_EMBY_API_KEY=replace-with-tertiary-emby-api-key
